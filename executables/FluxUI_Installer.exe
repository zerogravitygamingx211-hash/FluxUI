@echo off
title FluxUI v1.0.0 Installer
color 0A

echo ========================================
echo   FluxUI Programming Language v1.0.0
echo   Complete Installer
echo ========================================
echo.
echo This will install FluxUI to:
echo C:\Program Files\FluxUI
echo.
echo Extracting files...
powershell -Command "Expand-Archive -Path 'FluxUI_Executables.zip' -DestinationPath 'C:\Program Files\FluxUI\bin' -Force"

echo Creating additional directories...
mkdir "C:\Program Files\FluxUI\lib" 2>nul
mkdir "C:\Program Files\FluxUI\docs" 2>nul
mkdir "C:\Program Files\FluxUI\samples" 2>nul

echo Copying Python files...
copy "..\Scripts\fluxui.py" "C:\Program Files\FluxUI\lib\" > nul 2>&1
copy "..\Scripts\parser.py" "C:\Program Files\FluxUI\lib\" > nul 2>&1
copy "..\Scripts\tokenizer.py" "C:\Program Files\FluxUI\lib\" > nul 2>&1
copy "..\Scripts\engine.py" "C:\Program Files\FluxUI\lib\" > nul 2>&1
copy "..\Scripts\components.py" "C:\Program Files\FluxUI\lib\" > nul 2>&1
copy "..\Scripts\ui_engine.py" "C:\Program Files\FluxUI\lib\" > nul 2>&1
copy "..\Scripts\fluxui_cli.py" "C:\Program Files\FluxUI\lib\" > nul 2>&1
copy "..\Scripts\fluxui_ide.py" "C:\Program Files\FluxUI\lib\" > nul 2>&1

echo Copying documentation...
copy "..\FluxUI_Language_Reference.md" "C:\Program Files\FluxUI\docs\" > nul 2>&1
copy "..\FluxUI_Instruction_Book.md" "C:\Program Files\FluxUI\docs\" > nul 2>&1

echo Copying samples...
copy "..\Test.flux" "C:\Program Files\FluxUI\samples\" > nul 2>&1
copy "..\test_executable.flux" "C:\Program Files\FluxUI\samples\" > nul 2>&1

echo Creating fluxui.exe alias...
copy "C:\Program Files\FluxUI\bin\FluxUI.exe" "C:\Program Files\FluxUI\bin\fluxui.exe" > nul 2>&1

echo Adding to system PATH...
setx PATH "%PATH%;C:\Program Files\FluxUI\bin" > nul 2>&1

echo Creating file associations...
reg add "HKEY_CLASSES_ROOT\.flux" /ve /d "FluxUIFile" /f > nul 2>&1
reg add "HKEY_CLASSES_ROOT\FluxUIFile" /ve /d "FluxUI Source File" /f > nul 2>&1
reg add "HKEY_CLASSES_ROOT\FluxUIFile\DefaultIcon" /ve /d "C:\Program Files\FluxUI\bin\FluxUI.exe,0" /f > nul 2>&1
reg add "HKEY_CLASSES_ROOT\FluxUIFile\shell\open\command" /ve /d "\"C:\Program Files\FluxUI\bin\FluxUI.exe\" \"%1\"" /f > nul 2>&1

echo Creating desktop shortcut...
powershell -Command "$WshShell = New-Object -comObject WScript.Shell; $Shortcut = $WshShell.CreateShortcut('%PUBLIC%\Desktop\FluxUI.lnk'); $Shortcut.TargetPath = 'C:\Program Files\FluxUI\bin\fluxui.exe'; $Shortcut.Description = 'FluxUI Programming Language v1.0.0'; $Shortcut.Save()" > nul 2>&1

echo.
echo ========================================
echo   Installation Complete!
echo ========================================
echo.
echo FluxUI v1.0.0 has been installed to:
echo C:\Program Files\FluxUI
echo.
echo You can now run:
echo fluxui --ver
echo fluxui program.flux
echo.
echo Please restart Command Prompt to use fluxui command.
echo.
pause
